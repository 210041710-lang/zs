# LLM provider configuration
# Fill in your own provider credentials before starting the service.
OPENAI_API_KEY=your_provider_api_key
OPENAI_BASE_URL=your_provider_base_url
OPENAI_MODEL=your_model_name

# Example:
# OPENAI_API_KEY=your_provider_api_key
# OPENAI_BASE_URL=your_provider_base_url
# OPENAI_MODEL=your_model_name
